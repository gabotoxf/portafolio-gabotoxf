generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model TestimonialInvite { 
  id          String   @id @default(uuid()) 
  token       String   @unique 
  clientName  String? 
  clientEmail String? 
  used        Boolean  @default(false) 
  expiresAt   DateTime? 
  createdAt   DateTime @default(now()) 
} 

model Testimonial { 
  id        String   @id @default(uuid()) 
  name      String 
  company   String? 
  position  String? 
  message   String 
  rating    Int? 
  image     String? 
  approved  Boolean  @default(false) 
  createdAt DateTime @default(now()) 
} 
